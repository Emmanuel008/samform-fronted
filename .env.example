# Copy to .env.local for local overrides, or set in your hosting dashboard before build.

# API server base URL (no trailing slash).
# Leave empty to use same-origin paths (/submit.php) when frontend and PHP share one host.
REACT_APP_API_BASE=https://sam.jitihada.co.tz

# Examples:
# Same server as PHP (recommended if API has no HTTPS):
# REACT_APP_API_BASE=
#
# HTTPS proxy on your domain:
# REACT_APP_API_BASE=https://your-domain.com
